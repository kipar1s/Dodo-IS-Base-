<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"
                   assembly="dodoisbase"
                   namespace="dodoisbase.Nhibernate.Entites">

	<class name="Oder" table="[Заказы]">
		<id name="ID_Заказа" column="[ID_Заказа]">
			<generator class="native" />
		</id>
		
		<property name="ID_Клиента" column="[ID_Клиента]" />

		<property name="Дата_заказа" column="[Дата_заказа]" />
		<property name="Сумма" column="[Сумма]" />
		<property name="Статус" column="[Статус]" />
		<property name="Адресс_доставки" column="[Адресс_доставки]" />
		<!-- Многие-ко-многим: один сотрудник → много заказов -->
        <many-to-one name="Personal" column="[ID_Сотрудника]" cascade="merge" />
		
		<!-- Один-ко-многим через Доставку -->
		<bag name="Dostavkas" table ="[Доставка]" inverse="true">
			<key column="[ID_Заказа]"/>
			<one-to-many class="Dostavka"/>
		</bag>
        <!-- Многие-ко-многим: заказ ↔ товары -->
		<bag name="TovarList" table ="[Состав_заказа]">
			 <key column="[ID_Заказа]"/>
			<many-to-many class="Tovar" column="[ID_Товара]"/>
			
		</bag> 
	</class>
</hibernate-mapping>